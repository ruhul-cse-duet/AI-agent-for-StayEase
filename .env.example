# StayEase — Environment Variables
# Copy this file to .env and fill in your values

# ── LLM: Choose ONE option ────────────────────────────────────────────────────

# Option A: Groq Cloud (free tier available → https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-70b-8192

# Option B: LM Studio (local model) — uncomment and comment out Groq vars above
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=lmstudio-community/Meta-Llama-3-8B-Instruct-GGUF

# ── Database ───────────────────────────────────────────────────────────────────
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stayease
