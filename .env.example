# StayEase — Environment Variables

# ── LLM: Choose ONE ──────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...............
GROQ_MODEL=llama3-70b-8192

# LM Studio (local) — uncomment and comment Groq above:
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=lmstudio-community/Meta-Llama-3-8B-Instruct-GGUF

# ── Token limit ───────────────────────────────────────────────────────────────
# Max tokens the LLM can generate per turn.
# 300 = short crisp replies  |  500 = slightly more detail
LLM_MAX_TOKENS=350

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stayease
